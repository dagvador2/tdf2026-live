generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ── Enums ──────────────────────────────────────────

enum StageType {
  road
  team_tt
  individual_tt
  mountain
}

enum StageStatus {
  upcoming
  live
  paused
  finished
}

enum EntryStatus {
  registered
  started
  tracking
  finished
  dnf
  dns
}

enum CheckpointType {
  start
  col
  sprint
  finish
}

enum GCMode {
  all
  complete_only
  categories
}

enum PostType {
  text
  photo
  result
  highlight
}

// ── Models ─────────────────────────────────────────

model Team {
  id          String   @id @default(cuid())
  name        String
  slug        String   @unique
  color       String
  logoUrl     String?  @map("logo_url")
  description String?
  riders      Rider[]
  createdAt   DateTime @default(now()) @map("created_at")

  @@map("teams")
}

model Rider {
  id           String  @id @default(cuid())
  firstName    String  @map("first_name")
  nickname     String?
  slug         String  @unique
  photoUrl     String? @map("photo_url")
  // Portrait détouré zoomé sur le visage — utilisé pour le médaillon sur la carte live
  photoZoomUrl String? @map("photo_zoom_url")
  teamId       String  @map("team_id")
  team         Team    @relation(fields: [teamId], references: [id])
  editionCount Int     @default(1) @map("edition_count")
  funFacts     Json?   @map("fun_facts")

  // Pre-fill pour le lien automatique quand le coureur se connecte avec cet email
  email String? @unique

  // Identifiant de l'appareil Traccar Client (OsmAnd) — code unique collé par le coureur dans l'app
  traccarDeviceId String? @unique @map("traccar_device_id")

  // Infos sportives (admin only)
  weightKg     Float?  @map("weight_kg")
  ftpWatts     Int?    @map("ftp_watts")
  level        String?
  jerseySize   String? @map("jersey_size")
  // Maillots additionnels d'autres équipes : Record<teamSlug, quantity>
  extraJerseys Json?   @map("extra_jerseys")

  // Logistique (JSONB)
  logistics Json?

  // Relation inverse Auth.js
  user User?

  entries   StageEntry[]
  createdAt DateTime     @default(now()) @map("created_at")

  @@map("riders")
}

model Stage {
  id          String       @id @default(cuid())
  number      Int          @unique
  name        String
  type        StageType
  date        DateTime
  distanceKm  Float        @map("distance_km")
  elevationM  Int          @map("elevation_m")
  gpxUrl      String?      @map("gpx_url")
  status      StageStatus  @default(upcoming)
  startTime   DateTime?    @map("start_time")
  endTime     DateTime?    @map("end_time")
  ttNthRider  Int          @default(3) @map("tt_nth_rider")
  teamTopN    Int          @default(3) @map("team_top_n")
  gcMode      GCMode       @default(all) @map("gc_mode")
  entries     StageEntry[]
  checkpoints Checkpoint[]
  posts       LivePost[]
  createdAt   DateTime     @default(now()) @map("created_at")

  @@map("stages")
}

model StageEntry {
  id           String        @id @default(cuid())
  riderId      String        @map("rider_id")
  rider        Rider         @relation(fields: [riderId], references: [id])
  stageId      String        @map("stage_id")
  stage        Stage         @relation(fields: [stageId], references: [id])
  status       EntryStatus   @default(registered)
  timeRecords  TimeRecord[]
  gpsPositions GpsPosition[]
  createdAt    DateTime      @default(now()) @map("created_at")

  @@unique([riderId, stageId])
  @@map("stage_entries")
}

model Checkpoint {
  id          String         @id @default(cuid())
  stageId     String         @map("stage_id")
  stage       Stage          @relation(fields: [stageId], references: [id])
  name        String
  type        CheckpointType
  latitude    Float
  longitude   Float
  radiusM     Int            @default(50) @map("radius_m")
  order       Int
  kmFromStart Float          @map("km_from_start")
  elevation   Int?
  timeRecords TimeRecord[]
  createdAt   DateTime       @default(now()) @map("created_at")

  @@map("checkpoints")
}

model TimeRecord {
  id           String     @id @default(cuid())
  entryId      String     @map("entry_id")
  entry        StageEntry @relation(fields: [entryId], references: [id])
  checkpointId String     @map("checkpoint_id")
  checkpoint   Checkpoint @relation(fields: [checkpointId], references: [id])
  timestamp    DateTime
  isManual     Boolean    @default(false) @map("is_manual")
  correctedBy  String?    @map("corrected_by")
  createdAt    DateTime   @default(now()) @map("created_at")

  @@unique([entryId, checkpointId])
  @@map("time_records")
}

model GpsPosition {
  id        BigInt     @id @default(autoincrement())
  entryId   String     @map("entry_id")
  entry     StageEntry @relation(fields: [entryId], references: [id])
  latitude  Float
  longitude Float
  altitude  Float?
  speed     Float?
  accuracy  Float?
  timestamp DateTime
  createdAt DateTime   @default(now()) @map("created_at")

  @@index([entryId, timestamp])
  @@index([createdAt])
  @@map("gps_positions")
}

model LivePost {
  id        String   @id @default(cuid())
  stageId   String   @map("stage_id")
  stage     Stage    @relation(fields: [stageId], references: [id])
  authorId  String   @map("author_id")
  type      PostType @default(text)
  content   String
  photoUrl  String?  @map("photo_url")
  pinned    Boolean  @default(false)
  createdAt DateTime @default(now()) @map("created_at")

  @@index([stageId, createdAt(sort: Desc)])
  @@map("live_posts")
}

model AdminUser {
  id          String   @id @default(cuid())
  email       String   @unique
  password    String
  displayName String   @map("display_name")
  createdAt   DateTime @default(now()) @map("created_at")

  @@map("admin_users")
}

// ── Histoires du Tour ──────────────────────────────

model TourStory {
  id                   String           @id @default(cuid())
  slug                 String           @unique
  title                String
  subtitle             String?
  year                 Int
  category             String // duel | drame | exploit | anecdote | controverse | victoire | col | coureur | explication
  heroImageUrl         String?          @map("hero_image_url")
  heroImageAttribution String?          @map("hero_image_attribution")
  heroImagePosition    String?          @map("hero_image_position") // CSS object-position override (ex: "center top")
  excerpt              String           @db.Text
  content              String           @db.Text
  readingTimeMin       Int              @map("reading_time_min")
  publishedAt          DateTime?        @map("published_at")
  scheduledFor         DateTime?        @map("scheduled_for")
  createdAt            DateTime         @default(now()) @map("created_at")
  updatedAt            DateTime         @updatedAt @map("updated_at")
  viewEvents           StoryViewEvent[]

  @@index([publishedAt])
  @@index([category])
  @@map("tour_stories")
}

model StoryViewEvent {
  id        String    @id @default(cuid())
  storyId   String    @map("story_id")
  story     TourStory @relation(fields: [storyId], references: [id], onDelete: Cascade)
  userId    String?   @map("user_id")
  user      User?     @relation(fields: [userId], references: [id], onDelete: SetNull)
  sessionId String?   @map("session_id")
  kind      String // view | read | share
  createdAt DateTime  @default(now()) @map("created_at")

  @@index([storyId, kind])
  @@index([createdAt])
  @@index([userId])
  @@map("story_view_events")
}

// ── Auth.js (NextAuth v5) — Portail coureur ────────

model User {
  id                      String                  @id @default(cuid())
  name                    String?
  email                   String?                 @unique
  emailVerified           DateTime?               @map("email_verified")
  image                   String?
  role                    String                  @default("pending") // "admin" | "rider" | "pending"
  riderId                 String?                 @unique @map("rider_id")
  rider                   Rider?                  @relation(fields: [riderId], references: [id])
  accounts                Account[]
  sessions                Session[]
  pushSubscriptions       PushSubscription[]
  notificationPreference  NotificationPreference?
  storyViewEvents         StoryViewEvent[]
  bingoTemplatesTargeting BingoCellTemplate[]     @relation("BingoTemplateTarget")
  bingoGrids              BingoGrid[]
  bingoAchievements       BingoAchievement[]
  questionnaire           Questionnaire?
  sponsoredBy             SponsorBlock[]          @relation("SponsorTarget")
  createdAt               DateTime                @default(now()) @map("created_at")

  @@map("users")
}

model Account {
  id                String  @id @default(cuid())
  userId            String  @map("user_id")
  type              String
  provider          String
  providerAccountId String  @map("provider_account_id")
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique @map("session_token")
  userId       String   @map("user_id")
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

// ── Notifications Push ─────────────────────────────

model PushSubscription {
  id         String   @id @default(cuid())
  userId     String   @map("user_id")
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  endpoint   String   @unique
  p256dh     String
  auth       String
  userAgent  String?  @map("user_agent")
  createdAt  DateTime @default(now()) @map("created_at")
  lastUsedAt DateTime @default(now()) @map("last_used_at")

  @@index([userId])
  @@map("push_subscriptions")
}

model NotificationPreference {
  id             String  @id @default(cuid())
  userId         String  @unique @map("user_id")
  user           User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  stageStart     Boolean @default(true) @map("stage_start")
  newStory       Boolean @default(true) @map("new_story")
  feedHighlights Boolean @default(true) @map("feed_highlights")
  myResults      Boolean @default(true) @map("my_results")

  @@map("notification_preferences")
}

// ── Bingo TDF ──────────────────────────────────────

enum BingoCategory {
  GENERIC
  GROUP_SPECIFIC
  SELF_REFERENTIAL
}

enum BingoAchievementType {
  SINGLE_LINE
  DOUBLE_LINE
  FULL_HOUSE
}

model BingoEvent {
  id        String   @id @default(cuid())
  slug      String   @unique
  name      String
  startsAt  DateTime @map("starts_at")
  endsAt    DateTime @map("ends_at")
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")

  templates BingoCellTemplate[]
  grids     BingoGrid[]

  @@index([isActive])
  @@map("bingo_events")
}

model BingoCellTemplate {
  id           String        @id @default(cuid())
  eventId      String        @map("event_id")
  text         String        @db.Text // peut contenir le placeholder {name}
  category     BingoCategory
  weight       Int           @default(10)
  targetUserId String?       @map("target_user_id")
  isActive     Boolean       @default(true) @map("is_active")
  createdAt    DateTime      @default(now()) @map("created_at")

  event      BingoEvent      @relation(fields: [eventId], references: [id], onDelete: Cascade)
  targetUser User?           @relation("BingoTemplateTarget", fields: [targetUserId], references: [id])
  cells      BingoGridCell[]

  @@index([eventId, category, isActive])
  @@index([targetUserId])
  @@map("bingo_cell_templates")
}

model BingoGrid {
  id           String    @id @default(cuid())
  eventId      String    @map("event_id")
  userId       String    @map("user_id")
  seed         String
  generatedAt  DateTime  @default(now()) @map("generated_at")
  revealedAt   DateTime? @map("revealed_at") // grille pré-générée : masquée jusqu'à ce que le coureur clique « Afficher ma grille »
  firstBingoAt DateTime? @map("first_bingo_at")
  fullHouseAt  DateTime? @map("full_house_at")

  event        BingoEvent         @relation(fields: [eventId], references: [id])
  user         User               @relation(fields: [userId], references: [id])
  cells        BingoGridCell[]
  achievements BingoAchievement[]

  @@unique([eventId, userId])
  @@index([firstBingoAt])
  @@map("bingo_grids")
}

model BingoGridCell {
  id             String        @id @default(cuid())
  gridId         String        @map("grid_id")
  templateId     String        @map("template_id")
  position       Int // 0..15 (row*4 + col)
  text           String        @db.Text
  category       BingoCategory
  validatedAt    DateTime?     @map("validated_at")
  validationNote String?       @map("validation_note") @db.VarChar(280)

  grid     BingoGrid         @relation(fields: [gridId], references: [id], onDelete: Cascade)
  template BingoCellTemplate @relation(fields: [templateId], references: [id])

  @@unique([gridId, position])
  @@index([gridId, validatedAt])
  @@map("bingo_grid_cells")
}

model BingoAchievement {
  id         String               @id @default(cuid())
  gridId     String               @map("grid_id")
  userId     String               @map("user_id")
  type       BingoAchievementType
  line       String // "ROW_0".."ROW_3" | "COL_0".."COL_3" | "DIAG_TLBR" | "DIAG_TRBL" | "FULL"
  achievedAt DateTime             @default(now()) @map("achieved_at")

  grid BingoGrid @relation(fields: [gridId], references: [id], onDelete: Cascade)
  user User      @relation(fields: [userId], references: [id])

  @@unique([gridId, type, line])
  @@index([userId, achievedAt])
  @@index([type, achievedAt])
  @@map("bingo_achievements")
}

// ── Questionnaire participants ─────────────────────

model Questionnaire {
  id             String    @id @default(cuid())
  userId         String    @unique @map("user_id")
  startedAt      DateTime  @default(now()) @map("started_at")
  completedAt    DateTime? @map("completed_at")
  knowledgeScore Int?      @map("knowledge_score") // figé à la complétion (somme des isCorrect du bloc 3)

  user        User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  answers     QuestionnaireAnswer[]
  sponsorings SponsorBlock[]

  @@index([completedAt])
  @@map("questionnaires")
}

model QuestionnaireAnswer {
  id              String   @id @default(cuid())
  questionnaireId String   @map("questionnaire_id")
  block           Int // 1, 2 ou 3
  questionKey     String   @map("question_key") // identifiant stable (ex: "b2_ricard_iso")
  answerText      String?  @map("answer_text") @db.VarChar(500) // bloc 1 (libre / choix)
  answerChoice    String?  @map("answer_choice") // bloc 2/3 : "A" | "B"
  isCorrect       Boolean? @map("is_correct") // bloc 3 uniquement, calculé serveur
  createdAt       DateTime @default(now()) @map("created_at")

  questionnaire Questionnaire @relation(fields: [questionnaireId], references: [id], onDelete: Cascade)

  @@unique([questionnaireId, questionKey])
  @@index([block])
  @@map("questionnaire_answers")
}

model SponsorBlock {
  id              String   @id @default(cuid())
  questionnaireId String   @map("questionnaire_id")
  targetUserId    String   @map("target_user_id")
  createdAt       DateTime @default(now()) @map("created_at")

  questionnaire Questionnaire @relation(fields: [questionnaireId], references: [id], onDelete: Cascade)
  targetUser    User          @relation("SponsorTarget", fields: [targetUserId], references: [id], onDelete: Cascade)
  facts         SponsorFact[]

  @@unique([questionnaireId, targetUserId])
  @@index([targetUserId])
  @@map("sponsor_blocks")
}

model SponsorFact {
  id             String   @id @default(cuid())
  sponsorBlockId String   @map("sponsor_block_id")
  questionKey    String   @map("question_key") // "manie" | "phrase" | "point_faible" | "rale" | "bouffe" | "marrant" | "bonus"
  answerText     String?  @map("answer_text") @db.VarChar(500)
  createdAt      DateTime @default(now()) @map("created_at")

  sponsorBlock SponsorBlock @relation(fields: [sponsorBlockId], references: [id], onDelete: Cascade)

  @@unique([sponsorBlockId, questionKey])
  @@index([sponsorBlockId])
  @@map("sponsor_facts")
}
