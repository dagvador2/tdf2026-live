# Live Twitch (CLM) — chaîne + API Helix pour la détection du direct
NEXT_PUBLIC_TWITCH_CHANNEL=
TWITCH_CLIENT_ID=
TWITCH_CLIENT_SECRET=
# Clé d'accès de l'overlay OBS et de l'API classement (?key=...)
LIVE_OVERLAY_KEY=tdf2026live

# Feature questionnaire participants
# true = routes /questionnaire et /admin/questionnaire actives ; sinon 404
FEATURE_QUESTIONNAIRE_ENABLED=false
# Optionnel : allowlist d'emails (séparés par des virgules). Vide = tous les connectés.
QUESTIONNAIRE_ALLOWED_EMAILS=

# Validateurs pastis : emails (compte Google) qui reçoivent les notifs push à
# chaque déclaration et peuvent ajuster le compteur de tout le monde, sans être
# passés admin. Séparés par des virgules. Vide = personne (aucune notif).
PASTIS_ADMIN_EMAILS=
